{
  "profiles": [
    { "id": "agnt_cpu_load", "label": "CPU Load", "provider": "system", "variable": "cpu_load", "samples": 12,
      "alerts": [{ "metric": "mean", "op": ">=", "threshold": 90, "severity": "warning", "message": "CPU load elevated" }] },
    { "id": "agnt_memory_used", "label": "Memory Used", "provider": "system", "variable": "memory_used_percent", "samples": 12,
      "alerts": [{ "metric": "mean", "op": ">=", "threshold": 92, "severity": "critical", "message": "Memory pressure critical" },
                 { "metric": "mean", "op": ">=", "threshold": 85, "severity": "warning", "message": "Memory pressure high" }] },
    { "id": "agnt_disk_free", "label": "Disk Free %", "provider": "system", "variable": "disk_free_percent", "path": ".", "samples": 8,
      "alerts": [{ "metric": "mean", "op": "<=", "threshold": 8, "severity": "critical", "message": "Disk space critical" },
                 { "metric": "mean", "op": "<=", "threshold": 15, "severity": "warning", "message": "Disk space low" }] },
    { "id": "agnt_process_count", "label": "Process Count", "provider": "system", "variable": "process_count", "samples": 8 },
    { "id": "agnt_uptime", "label": "System Uptime", "provider": "system", "variable": "uptime", "samples": 8 },

    { "id": "agnt_loopback_ping", "label": "Loopback Ping (ICMP)", "provider": "ping", "host": "127.0.0.1", "port": 80, "count": 6 },
    { "id": "agnt_cloudflare_ping", "label": "Cloudflare Ping", "provider": "ping", "host": "1.1.1.1", "port": 443, "count": 6 },
    { "id": "agnt_google_ping", "label": "Google DNS Ping", "provider": "ping", "host": "8.8.8.8", "port": 53, "count": 6 },

    { "id": "goes_xray", "label": "GOES X-ray Flux (0.1-0.8nm)", "provider": "goes_xray" },
    { "id": "noaa_kp", "label": "Planetary K-Index (Kp)", "provider": "noaa_kp" },
    { "id": "noaa_sunspots", "label": "Daily Sunspot Number", "provider": "noaa_sunspots" },
    { "id": "solar_wind_bz", "label": "Solar Wind Bz (nT)", "provider": "solar_wind" },

    { "id": "nyc_temperature", "label": "NYC Temperature", "provider": "openmeteo", "lat": 40.71, "lon": -74.01, "variable": "temperature_2m" },
    { "id": "nyc_pressure", "label": "NYC Pressure (hPa)", "provider": "openmeteo", "lat": 40.71, "lon": -74.01, "variable": "pressure_msl" },
    { "id": "nyc_wind", "label": "NYC Wind Speed", "provider": "openmeteo", "lat": 40.71, "lon": -74.01, "variable": "wind_speed_10m" },
    { "id": "nyc_humidity", "label": "NYC Humidity", "provider": "openmeteo", "lat": 40.71, "lon": -74.01, "variable": "relative_humidity_2m" },
    { "id": "nyc_weather_current", "label": "NYC Weather (Current)", "provider": "openmeteo_current", "lat": 40.71, "lon": -74.01 },
    { "id": "nyc_air_quality", "label": "NYC Air Quality (AQI)", "provider": "openmeteo_air", "lat": 40.71, "lon": -74.01, "variable": "us_aqi",
      "alerts": [{ "metric": "mean", "op": ">=", "threshold": 150, "severity": "warning", "message": "AQI unhealthy" }] },
    { "id": "nyc_uv_index", "label": "NYC UV Index", "provider": "openmeteo_uv", "lat": 40.71, "lon": -74.01 },
    { "id": "waqi_nyc", "label": "WAQI NYC AQI", "provider": "waqi", "city": "newyork" },

    { "id": "regional_quakes", "label": "Regional Earthquakes", "provider": "usgs_earthquake", "lat": 40.71, "lon": -74.01, "radius_km": 2500, "days": 7, "min_magnitude": 1.0 },

    { "id": "btc_price", "label": "Bitcoin Price (USD)", "provider": "coingecko", "coin": "bitcoin" },
    { "id": "eth_price", "label": "Ethereum Price (USD)", "provider": "coingecko", "coin": "ethereum" },
    { "id": "fear_greed", "label": "Fear & Greed Index", "provider": "fear_greed" },

    { "id": "github_agnt_evo", "label": "agnt-evo Repo", "provider": "github", "repo": "jacksonjp0311-gif/agnt-evo" },
    { "id": "github_triadix", "label": "Triadix-Governance Repo", "provider": "github", "repo": "jacksonjp0311-gif/Triadix-Governance" },
    { "id": "github_user_activity", "label": "GitHub User Activity", "provider": "github_user", "user": "jacksonjp0311-gif" },
    { "id": "github_repos_stars", "label": "GitHub Repos (Stars)", "provider": "github_repos", "user": "jacksonjp0311-gif" },

    { "id": "iss_location", "label": "ISS Position", "provider": "iss" },
    { "id": "nasa_neo", "label": "Near-Earth Objects (Today)", "provider": "nasa_neo" },

    { "id": "hn_top", "label": "Hacker News Top", "provider": "hackernews", "type": "top" },
    { "id": "hn_new", "label": "Hacker News New", "provider": "hackernews", "type": "new" },

    { "id": "dns_agnt_gg", "label": "DNS: agnt.gg", "provider": "dns", "domain": "agnt.gg", "dns_provider": "google" },
    { "id": "npm_agnt", "label": "npm: agnt package", "provider": "npm", "package": "agnt" }
